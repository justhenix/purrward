# Drizzle
# Replace with your DB credentials!
DATABASE_URL=libsql://db-name-user.turso.io
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"
DATABASE_AUTH_TOKEN=your-database-auth-token

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
# Local-only password reset helper. Never enable on production hosts.
DEV_AUTH_RESET_LINKS=false

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_VET_MODEL=gemini-3.1-flash-lite
